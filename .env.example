# Bỏ qua DATABASE_URL hoặc để trống → demo dùng SQLite (warehouse_demo.db).
# Chỉ bật khi Postgres đã cấu hình đúng user/password:
# DATABASE_URL=postgresql+asyncpg://postgres:mat_khau_that@localhost:5432/warehouse_db
# Nếu DATABASE_URL sai nhưng chưa muốn sửa: WAREHOUSE_SQLITE_DEMO=1

# Google AI Studio: https://aistudio.google.com/apikey (nếu báo expired → tạo key mới)
# File .env được load với override=True để thắng biến môi trường Windows (GOOGLE_API_KEY / GEMINI_API_KEY cũ).
GEMINI_API_KEY=
# Ví dụ khớp REST: gemini-flash-latest
# GEMINI_MODEL=gemini-flash-latest
# Khi API 503 / quá tải: tăng số lần thử hoặc chờ dài hơn
# GEMINI_MAX_RETRIES=6
# GEMINI_RETRY_BASE_SECONDS=2

# Tuỳ chọn: log phía MCP server (tiến trình warehouse_server.py)
# WAREHOUSE_MCP_DEBUG=1
